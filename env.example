# Database Configuration
# Use the Supabase transaction pooler connection string with postgres-js/Drizzle.
DATABASE_URL=postgresql://postgres.your-project-ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Google Calendar Configuration
NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=your_actual_key
NEXT_PUBLIC_GOOGLE_CALENDAR_ID=your_actual_id
NEXT_PUBLIC_CALENDAR_TIMEZONE=America/Phoenix
NEXT_PUBLIC_CALENDAR_DEBUG=false
NEXT_PUBLIC_GOOGLE_CALENDAR_SUBSCRIPTION_URL=

# SMTP Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email
SMTP_PASS=your_password
RECIPIENT_EMAIL=your_recipient
CONTACT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_token

# Google Sheets Integration (Apps Script Webhook URL)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Hackathon Promo Configuration
NEXT_PUBLIC_SHOW_HACKATHON=true

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
